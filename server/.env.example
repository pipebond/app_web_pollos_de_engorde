# Server env example
# Copy this file to server/.env and replace values.

PORT=3001
TRUST_PROXY=1

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=pollos_de_engorde_db

# Use a long random string in production.
JWT_SECRET=change_this_to_a_long_random_secret

# Frontend URL allowed by CORS (production domain)
CLIENT_ORIGIN=https://your-frontend-domain.com
